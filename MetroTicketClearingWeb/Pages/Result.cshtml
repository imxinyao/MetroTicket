@page
@model MetroTicketClearingWeb.Pages.ResultModel
@{
    ViewData["Title"] = "清分结果展示";
}

<div class="header page-header">
    <div>
        <h1>清分结果展示</h1>
        <p class="sub-text">根据交易数据、已发布时刻表和清分规则进行后端清分</p>
    </div>
    <button type="button" onclick="runClearing()">执行/刷新清分</button>
</div>

<div class="panel">
    <h3>当前清分参数</h3>
    <div id="ruleInfo" class="message-text">点击“执行清分”后读取后端规则参数。</div>
    <div id="ruleDescription" class="sub-text" style="margin-top: 10px;">
        说明：只有成功匹配已发布时刻表的刷卡交易才参与清分，无法匹配时刻表的交易不参与清分。
    </div>
</div>

<div class="cards dashboard-cards">
    <div class="card">
        <h3>参与清分交易数</h3>
        <p id="normalTradeCount">0</p>
    </div>
    <div class="card">
        <h3>异常交易数</h3>
        <p id="exceptionTradeCount" class="danger-text">0</p>
    </div>
    <div class="card">
        <h3>清分总金额</h3>
        <p id="totalClearingAmount">0.00</p>
    </div>
</div>

<div class="panel">
    <h3>线路清分汇总</h3>
    <table>
        <thead>
            <tr>
                <th>线路</th>
                <th>清分金额</th>
            </tr>
        </thead>
        <tbody id="summaryTableBody">
            <tr>
                <td colspan="2">点击“执行清分”后显示结果</td>
            </tr>
        </tbody>
    </table>
</div>

<div class="panel">
    <h3>交易清分总览</h3>
    <div class="sub-text" style="margin-bottom:12px;">
        说明：这里只展示已经成功匹配已发布时刻表并参与清分的交易。无法匹配时刻表的正常交易不会进入清分结果。
        “路径方案数”表示候选方案个数，“线路分摊条数”表示展开后涉及的线路金额拆分记录数。点击“查看明细”可在当前交易下方展开具体分摊结果。
    </div>

    <table>
        <thead>
            <tr>
                <th>交易ID</th>
                <th>卡号</th>
                <th>进站站点</th>
                <th>出站站点</th>
                <th>支付金额</th>
                <th>路径方案数</th>
                <th>线路分摊条数</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody id="tradeTableBody">
            <tr>
                <td colspan="8">点击“执行清分”后显示结果</td>
            </tr>
        </tbody>
    </table>
</div>

<div id="page-config" data-api-base-url="@Model.ApiBaseUrl"></div>

@section Scripts {
    <script>
        const apiBaseUrl = document.getElementById("page-config").dataset.apiBaseUrl + "/api";

        let tradeDetailMap = {};
        let currentExpandedTradeId = null;

        const miniLineColors = {
            "L01": "#d9363e",
            "L02": "#2f6fd6",
            "L03": "#26a65b",
            "1": "#d9363e",
            "2": "#2f6fd6",
            "3": "#26a65b"
        };

        let miniNetworkCache = null;

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#39;");
        }

        function toNumber(value) {
            const number = Number(value ?? 0);
            return Number.isNaN(number) ? 0 : number;
        }

        function groupRowsByPath(rows) {
            const groups = {};
            rows.forEach(row => {
                const key = row.pathGroup || "方案1";
                if (!groups[key]) {
                    groups[key] = [];
                }
                groups[key].push(row);
            });
            return groups;
        }

        function buildPathPreviewCell(pathText, rowSpan) {
            const safePathText = escapeHtml(pathText);

            return `
                <td rowspan="${rowSpan}">
                    <div>
                        <span>${safePathText}</span>
                        <button type="button"
                                class="path-preview-btn"
                                data-path="${safePathText}"
                                onclick="togglePathPreview(this)">
                            预览路径
                        </button>
                    </div>

                    <div class="path-preview-box">
                        <div class="path-preview-title">路径预览</div>
                        <div class="path-preview-subtitle"></div>
                        <svg class="path-preview-svg" viewBox="0 0 1180 700"></svg>
                    </div>
                </td>
            `;
        }

        function buildDetailMergedTable(rows) {
            if (!rows || rows.length === 0) {
                return `<div class="sub-text">该交易暂无清分明细。</div>`;
            }

            const groups = groupRowsByPath(rows);
            const groupNames = Object.keys(groups);

            let html = `
                <div style="padding:12px 0 4px 0;">
                    <strong>清分明细</strong>
                </div>
                <table style="margin-top:8px;">
                    <thead>
                        <tr>
                            <th>路径方案</th>
                            <th>路径摘要</th>
                            <th>换乘说明</th>
                            <th>清分线路</th>
                            <th>清分金额</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            groupNames.forEach(groupName => {
                const items = groups[groupName];

                items.forEach((item, index) => {
                    html += `<tr>`;

                    if (index === 0) {
                        html += `<td rowspan="${items.length}">${escapeHtml(groupName)}</td>`;
                        html += buildPathPreviewCell(item.pathText, items.length);
                        html += `<td rowspan="${items.length}">${escapeHtml(item.transferText)}</td>`;
                    }

                    html += `<td>${escapeHtml(item.line)}</td>`;
                    html += `<td>${toNumber(item.amount).toFixed(2)}</td>`;
                    html += `</tr>`;
                });
            });

            html += `
                    </tbody>
                </table>
            `;

            return html;
        }

        function collapseCurrentDetail() {
            if (currentExpandedTradeId === null) {
                return;
            }

            const oldDetailRow = document.getElementById(`detail-row-${currentExpandedTradeId}`);
            const oldButton = document.getElementById(`toggle-btn-${currentExpandedTradeId}`);
            const oldMainRow = document.getElementById(`trade-row-${currentExpandedTradeId}`);

            if (oldDetailRow) {
                oldDetailRow.remove();
            }

            if (oldButton) {
                oldButton.textContent = "查看明细";
            }

            if (oldMainRow) {
                oldMainRow.style.backgroundColor = "";
            }

            currentExpandedTradeId = null;
        }

        function toggleTradeDetails(transactionId) {
            const targetDetailRow = document.getElementById(`detail-row-${transactionId}`);
            const targetButton = document.getElementById(`toggle-btn-${transactionId}`);
            const targetMainRow = document.getElementById(`trade-row-${transactionId}`);

            if (targetDetailRow) {
                collapseCurrentDetail();
                return;
            }

            collapseCurrentDetail();

            const rows = tradeDetailMap[transactionId] || [];
            const insertRow = document.createElement("tr");
            insertRow.id = `detail-row-${transactionId}`;

            insertRow.innerHTML = `
                <td colspan="8" style="background:#f8fbff; padding:16px;">
                    <div style="margin-bottom:10px;">
                        <strong>当前交易：</strong>${escapeHtml(transactionId)}
                    </div>
                    ${buildDetailMergedTable(rows)}
                </td>
            `;

            targetMainRow.insertAdjacentElement("afterend", insertRow);

            if (targetButton) {
                targetButton.textContent = "收起明细";
            }

            if (targetMainRow) {
                targetMainRow.style.backgroundColor = "#eef5ff";
            }

            currentExpandedTradeId = transactionId;
        }

        function renderRuleInfo(data) {
            const ruleInfo = document.getElementById("ruleInfo");
            const ruleDescription = document.getElementById("ruleDescription");

            const mode = data.clearingMode || "-";
            const transferCoefficient = data.transferCoefficient ?? "-";
            const timetableMatchedTradeCount = data.timetableMatchedTradeCount ?? 0;

            if (mode === "shortest") {
                ruleInfo.textContent = `当前清分模式：最短路径清分；当前换乘贡献系数：${transferCoefficient}`;
                ruleDescription.textContent = `说明：系统仅对成功匹配已发布时刻表的刷卡交易进行清分；无法匹配时刻表的交易不参与清分。本次已发布时刻表匹配交易数：${timetableMatchedTradeCount}。`;
            } else if (mode === "multi") {
                ruleInfo.textContent = "当前清分模式：多路径概率清分";
                ruleDescription.textContent = `说明：系统仅对成功匹配已发布时刻表的刷卡交易进行清分；无法匹配时刻表的交易不参与清分。该模式按候选路径概率进行分摊。本次已发布时刻表匹配交易数：${timetableMatchedTradeCount}。`;
            } else {
                ruleInfo.textContent = `当前清分模式：${mode}`;
                ruleDescription.textContent = `说明：清分参数由后端从数据库规则表读取；只有成功匹配已发布时刻表的交易才参与清分。本次已发布时刻表匹配交易数：${timetableMatchedTradeCount}。`;
            }
        }

        function renderSummary(summary) {
            const summaryTableBody = document.getElementById("summaryTableBody");

            if (!summary || summary.length === 0) {
                summaryTableBody.innerHTML = `<tr><td colspan="2">暂无线路清分汇总数据</td></tr>`;
                return;
            }

            summaryTableBody.innerHTML = summary.map(item => `
                <tr>
                    <td>${escapeHtml(item.lineName ?? "-")}</td>
                    <td>${toNumber(item.clearingAmount).toFixed(2)}</td>
                </tr>
            `).join("");
        }

        function renderTrades(trades) {
            const tradeTableBody = document.getElementById("tradeTableBody");

            if (!trades || trades.length === 0) {
                tradeTableBody.innerHTML = `<tr><td colspan="8">暂无可清分交易数据</td></tr>`;
                return;
            }

            tradeTableBody.innerHTML = trades.map(item => {
                const tradeId = item.transactionId;
                const amount = toNumber(item.payAmount);

                return `
                    <tr id="trade-row-${tradeId}">
                        <td>${escapeHtml(tradeId)}</td>
                        <td>${escapeHtml(item.cardNo ?? "-")}</td>
                        <td>${escapeHtml(item.entryStationName ?? "无进站记录")}</td>
                        <td>${escapeHtml(item.exitStationName ?? "无出站记录")}</td>
                        <td>${amount.toFixed(2)}</td>
                        <td>${escapeHtml(item.pathSchemeCount ?? 0)}</td>
                        <td>${escapeHtml(item.lineAllocationCount ?? 0)}</td>
                        <td>
                            <button type="button" id="toggle-btn-${tradeId}" onclick="toggleTradeDetails(${tradeId})">查看明细</button>
                        </td>
                    </tr>
                `;
            }).join("");
        }

        function buildTradeDetailMap(details) {
            tradeDetailMap = {};

            if (!details || details.length === 0) {
                return;
            }

            details.forEach(item => {
                const tradeId = item.transactionId;

                if (!tradeDetailMap[tradeId]) {
                    tradeDetailMap[tradeId] = [];
                }

                tradeDetailMap[tradeId].push({
                    transactionId: item.transactionId,
                    pathGroup: item.pathGroup ?? "方案1",
                    pathText: item.pathText ?? "-",
                    transferText: item.transferText ?? "-",
                    line: item.lineName ?? "-",
                    amount: toNumber(item.clearingAmount)
                });
            });
        }

        async function getMiniNetworkData() {
            if (miniNetworkCache) {
                return miniNetworkCache;
            }

            const response = await fetch(`${apiBaseUrl}/lines/network`);

            if (!response.ok) {
                throw new Error(`线网接口请求失败：${response.status}`);
            }

            miniNetworkCache = await response.json();
            normalizeMiniTransferStations(miniNetworkCache);

            return miniNetworkCache;
        }

        function normalizeMiniTransferStations(data) {
            const transferCodes = ["D", "E", "I"];

            data.stations.forEach(station => {
                if (transferCodes.includes(station.stationCode)) {
                    station.isTransfer = true;
                }
            });
        }

        async function togglePathPreview(button) {
            const cell = button.closest("td");
            const previewBox = cell.querySelector(".path-preview-box");
            const svg = previewBox.querySelector(".path-preview-svg");
            const subtitle = previewBox.querySelector(".path-preview-subtitle");
            const pathSummary = button.getAttribute("data-path");

            if (!pathSummary || pathSummary === "-") {
                alert("当前方案没有路径摘要，无法预览。");
                return;
            }

            const isActive = previewBox.classList.contains("active");

            document.querySelectorAll(".path-preview-box.active").forEach(box => {
                if (box !== previewBox) {
                    box.classList.remove("active");
                }
            });

            if (isActive) {
                previewBox.classList.remove("active");
                return;
            }

            previewBox.classList.add("active");
            subtitle.textContent = pathSummary;

            try {
                const data = await getMiniNetworkData();
                drawMiniPathPreview(svg, data, pathSummary);
            } catch (error) {
                console.error(error);
                svg.innerHTML = "";
                subtitle.textContent = "线网数据加载失败，请检查后端接口。";
            }
        }

        function drawMiniPathPreview(svg, data, pathSummary) {
            svg.innerHTML = "";

            const stationMap = {};
            const stationNameMap = {};

            data.stations.forEach(station => {
                stationMap[station.stationId] = station;
                stationNameMap[station.stationName] = station;
            });

            const pathStationNames = parsePathSummary(pathSummary);
            const pathStationIds = pathStationNames
                .map(name => stationNameMap[name]?.stationId)
                .filter(id => id !== undefined && id !== null);

            const highlightSectionKeys = new Set();

            for (let i = 0; i < pathStationIds.length - 1; i++) {
                const fromId = pathStationIds[i];
                const toId = pathStationIds[i + 1];

                highlightSectionKeys.add(`${fromId}-${toId}`);
                highlightSectionKeys.add(`${toId}-${fromId}`);
            }

            drawMiniBackgroundSections(svg, data.sections, stationMap, highlightSectionKeys);
            drawMiniHighlightSections(svg, data.sections, stationMap, highlightSectionKeys);
            drawMiniStations(svg, data.stations, pathStationIds);
            drawMiniPathLabels(svg, data.stations, pathStationIds);
        }

        function parsePathSummary(pathSummary) {
            return String(pathSummary ?? "")
                .replaceAll("→", ",")
                .replaceAll("->", ",")
                .replaceAll("-", ",")
                .replaceAll("，", ",")
                .split(",")
                .map(x => x.trim())
                .filter(x => x.length > 0);
        }

        function drawMiniBackgroundSections(svg, sections, stationMap, highlightSectionKeys) {
            sections.forEach(section => {
                const from = stationMap[section.fromStationId];
                const to = stationMap[section.toStationId];

                if (!from || !to) {
                    return;
                }

                const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                line.setAttribute("x1", from.x);
                line.setAttribute("y1", from.y);
                line.setAttribute("x2", to.x);
                line.setAttribute("y2", to.y);
                line.setAttribute("stroke", getMiniLineColor(section));
                line.setAttribute("stroke-width", "10");
                line.setAttribute("stroke-linecap", "round");
                line.setAttribute("opacity", highlightSectionKeys.size > 0 ? "0.18" : "0.9");

                svg.appendChild(line);
            });
        }

        function drawMiniHighlightSections(svg, sections, stationMap, highlightSectionKeys) {
            sections.forEach(section => {
                const key = `${section.fromStationId}-${section.toStationId}`;

                if (!highlightSectionKeys.has(key)) {
                    return;
                }

                const from = stationMap[section.fromStationId];
                const to = stationMap[section.toStationId];

                if (!from || !to) {
                    return;
                }

                const shadow = document.createElementNS("http://www.w3.org/2000/svg", "line");
                shadow.setAttribute("x1", from.x);
                shadow.setAttribute("y1", from.y);
                shadow.setAttribute("x2", to.x);
                shadow.setAttribute("y2", to.y);
                shadow.setAttribute("stroke", "rgba(249, 115, 22, 0.28)");
                shadow.setAttribute("stroke-width", "24");
                shadow.setAttribute("stroke-linecap", "round");

                const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                line.setAttribute("x1", from.x);
                line.setAttribute("y1", from.y);
                line.setAttribute("x2", to.x);
                line.setAttribute("y2", to.y);
                line.setAttribute("stroke", getMiniLineColor(section));
                line.setAttribute("stroke-width", "16");
                line.setAttribute("stroke-linecap", "round");

                svg.appendChild(shadow);
                svg.appendChild(line);
            });
        }

        function drawMiniStations(svg, stations, pathStationIds) {
            stations.forEach(station => {
                const highlighted = pathStationIds.includes(station.stationId);

                if (station.isTransfer) {
                    drawMiniTransferStation(svg, station, highlighted);
                } else {
                    drawMiniNormalStation(svg, station, highlighted);
                }
            });
        }

        function drawMiniNormalStation(svg, station, highlighted) {
            const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");

            circle.setAttribute("cx", station.x);
            circle.setAttribute("cy", station.y);
            circle.setAttribute("r", highlighted ? "16" : "11");
            circle.setAttribute("fill", highlighted ? "#fff7ed" : "#ffffff");
            circle.setAttribute("stroke", highlighted ? "#f97316" : "#cbd5e1");
            circle.setAttribute("stroke-width", highlighted ? "5" : "3");

            svg.appendChild(circle);
        }

        function drawMiniTransferStation(svg, station, highlighted) {
            const halo = document.createElementNS("http://www.w3.org/2000/svg", "circle");
            halo.setAttribute("cx", station.x);
            halo.setAttribute("cy", station.y);
            halo.setAttribute("r", highlighted ? "25" : "20");
            halo.setAttribute("fill", highlighted ? "rgba(251, 146, 60, 0.18)" : "#ffffff");
            halo.setAttribute("stroke", highlighted ? "rgba(249, 115, 22, 0.45)" : "rgba(17, 24, 39, 0.18)");
            halo.setAttribute("stroke-width", highlighted ? "8" : "5");

            const outer = document.createElementNS("http://www.w3.org/2000/svg", "circle");
            outer.setAttribute("cx", station.x);
            outer.setAttribute("cy", station.y);
            outer.setAttribute("r", highlighted ? "18" : "15");
            outer.setAttribute("fill", "#ffffff");
            outer.setAttribute("stroke", highlighted ? "#f97316" : "#111827");
            outer.setAttribute("stroke-width", highlighted ? "5" : "4");

            const inner = document.createElementNS("http://www.w3.org/2000/svg", "circle");
            inner.setAttribute("cx", station.x);
            inner.setAttribute("cy", station.y);
            inner.setAttribute("r", "6");
            inner.setAttribute("fill", highlighted ? "#f97316" : "#111827");

            svg.appendChild(halo);
            svg.appendChild(outer);
            svg.appendChild(inner);
        }

        function drawMiniPathLabels(svg, stations, pathStationIds) {
            stations.forEach(station => {
                if (!pathStationIds.includes(station.stationId)) {
                    return;
                }

                const offset = getMiniStationLabelOffset(station.stationCode);

                const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
                text.setAttribute("x", station.x + offset.dx);
                text.setAttribute("y", station.y + offset.dy);
                text.setAttribute("font-size", station.isTransfer ? "18" : "16");
                text.setAttribute("font-weight", "800");
                text.setAttribute("fill", "#111827");
                text.textContent = station.stationName;

                svg.appendChild(text);
            });
        }

        function getMiniStationLabelOffset(code) {
            const offsets = {
                "A": { dx: -12, dy: -30 },
                "B": { dx: -12, dy: -30 },
                "C": { dx: -12, dy: -30 },
                "D": { dx: -16, dy: -36 },
                "E": { dx: -16, dy: -36 },
                "F": { dx: 20, dy: 5 },
                "G": { dx: 20, dy: 5 },
                "H": { dx: 24, dy: 6 },
                "I": { dx: -62, dy: 5 },
                "J": { dx: -12, dy: -30 },
                "K": { dx: -12, dy: -30 },
                "L": { dx: -12, dy: -30 }
            };

            return offsets[code] || { dx: 12, dy: -12 };
        }

        function getMiniLineColor(section) {
            return miniLineColors[section.lineCode] || miniLineColors[String(section.lineId)] || "#64748b";
        }

        async function runClearing() {
            const summaryTableBody = document.getElementById("summaryTableBody");
            const tradeTableBody = document.getElementById("tradeTableBody");

            collapseCurrentDetail();
            tradeDetailMap = {};

            try {
                summaryTableBody.innerHTML = `<tr><td colspan="2">正在执行后端清分...</td></tr>`;
                tradeTableBody.innerHTML = `<tr><td colspan="8">正在执行后端清分...</td></tr>`;

                document.getElementById("normalTradeCount").textContent = "0";
                document.getElementById("exceptionTradeCount").textContent = "0";
                document.getElementById("totalClearingAmount").textContent = "0.00";

                const response = await fetch(`${apiBaseUrl}/Clearing/run`, {
                    method: "POST"
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`清分接口请求失败：${response.status} ${errorText}`);
                }

                const data = await response.json();

                renderRuleInfo(data);

                document.getElementById("normalTradeCount").textContent = data.normalTradeCount ?? 0;
                document.getElementById("exceptionTradeCount").textContent = data.exceptionTradeCount ?? 0;
                document.getElementById("totalClearingAmount").textContent = toNumber(data.totalClearingAmount).toFixed(2);

                renderSummary(data.summary || []);
                buildTradeDetailMap(data.details || []);
                renderTrades(data.trades || []);

            } catch (error) {
                console.error(error);

                document.getElementById("ruleInfo").textContent = "清分执行失败。";
                document.getElementById("ruleDescription").textContent = error.message || "请检查后端服务是否启动，以及接口地址是否正确。";

                summaryTableBody.innerHTML = `<tr><td colspan="2">清分失败</td></tr>`;
                tradeTableBody.innerHTML = `<tr><td colspan="8">清分失败，请检查后端服务是否启动</td></tr>`;
            }
        }

        async function loadLatestResult() {
            const summaryTableBody = document.getElementById("summaryTableBody");
            const tradeTableBody = document.getElementById("tradeTableBody");

            collapseCurrentDetail();
            tradeDetailMap = {};

            try {
                summaryTableBody.innerHTML = `<tr><td colspan="2">正在读取最近一次清分结果...</td></tr>`;
                tradeTableBody.innerHTML = `<tr><td colspan="8">正在读取最近一次清分结果...</td></tr>`;

                const response = await fetch(`${apiBaseUrl}/Clearing/latest`);

                if (response.status === 404) {
                    summaryTableBody.innerHTML = `<tr><td colspan="2">暂无历史清分结果，请点击“执行清分”。</td></tr>`;
                    tradeTableBody.innerHTML = `<tr><td colspan="8">暂无历史清分结果，请点击“执行清分”。</td></tr>`;
                    return;
                }

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`读取最近清分结果失败：${response.status} ${errorText}`);
                }

                const data = await response.json();

                renderRuleInfo(data);

                document.getElementById("normalTradeCount").textContent = data.normalTradeCount ?? 0;
                document.getElementById("exceptionTradeCount").textContent = data.exceptionTradeCount ?? 0;
                document.getElementById("totalClearingAmount").textContent = toNumber(data.totalClearingAmount).toFixed(2);

                renderSummary(data.summary || []);
                buildTradeDetailMap(data.details || []);
                renderTrades(data.trades || []);

            } catch (error) {
                console.error(error);

                summaryTableBody.innerHTML = `<tr><td colspan="2">读取历史清分结果失败</td></tr>`;
                tradeTableBody.innerHTML = `<tr><td colspan="8">读取历史清分结果失败，请检查后端服务是否启动</td></tr>`;
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            loadLatestResult();
        });
    </script>
}