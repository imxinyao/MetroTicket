<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 票务清分系统</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MetroTicketClearingWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/style.css" asp-append-version="true" />
</head>
<body>
    <div class="sidebar">
        <h2>票务清分系统</h2>
        <ul>
            <li>
                <a href="/" class="nav-link-custom @(ViewContext.HttpContext.Request.Path == "/" ? "active" : "")">首页</a>
            </li>
            <li>
                <a href="/Network" class="nav-link-custom @(ViewContext.HttpContext.Request.Path == "/Network" ? "active" : "")">线网图展示</a>
            </li>
            <li>
                <a href="/Data" class="nav-link-custom @(ViewContext.HttpContext.Request.Path == "/Data" ? "active" : "")">票务数据管理</a>
            </li>
            <li>
                <a href="/Timetable" class="nav-link-custom @(ViewContext.HttpContext.Request.Path == "/Timetable" ? "active" : "")">时刻表与清分准备</a>
            </li>
            <li>
                <a href="/Rules" class="nav-link-custom @(ViewContext.HttpContext.Request.Path == "/Rules" ? "active" : "")">清分规则配置</a>
            </li>
            <li>
                <a href="/Result" class="nav-link-custom @(ViewContext.HttpContext.Request.Path == "/Result" ? "active" : "")">清分结果展示</a>
            </li>
        </ul>
    </div>

    <div class="main">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>