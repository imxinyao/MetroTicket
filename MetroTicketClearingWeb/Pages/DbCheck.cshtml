@page
@model MetroTicketClearingWeb.Pages.DbCheckModel
@{
    ViewData["Title"] = "数据库检查页";
}

<div class="container mt-4">
    <h1 class="mb-4">地铁票务清分系统 - 数据库检查页</h1>

    @if (Model.DbConnected)
    {
        <div class="alert alert-success">
            <strong>数据库状态：</strong>@Model.DbMessage
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <strong>数据库状态：</strong>@Model.DbMessage
        </div>
    }

    <div class="card mt-3">
        <div class="card-header">
            <strong>基础表检查结果</strong>
        </div>
        <div class="card-body">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>表名</th>
                        <th>是否存在</th>
                        <th>记录数</th>
                        <th>说明</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Tables)
                    {
                        <tr>
                            <td>@item.TableName</td>
                            <td>
                                @if (item.Exists)
                                {
                                    <span class="text-success">是</span>
                                }
                                else
                                {
                                    <span class="text-danger">否</span>
                                }
                            </td>
                            <td>@item.RecordCount</td>
                            <td>@item.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a href="/" class="btn btn-secondary">返回首页</a>
    </div>
</div>