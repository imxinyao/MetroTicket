@page
@model MetroTicketClearingWeb.Pages.TimetableModel
@{
    ViewData["Title"] = "时刻表与清分准备";
}

<div class="header page-header">
    <div>
        <h1>时刻表与清分准备</h1>
        <p class="sub-text">用于查看时刻表主数据，并为后续刷卡匹配与清分提供基础。</p>
    </div>
    <div>
        <button type="button" onclick="toggleImportPanel()">导入时刻表</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="panel">
        <div class="message-text danger-text">@Model.ErrorMessage</div>
    </div>
}

<div class="panel" id="importPanel" style="display:@(!string.IsNullOrWhiteSpace(Model.ImportMessage) ? "block" : "none");">
    <h3>时刻表导入</h3>

    <form method="post" enctype="multipart/form-data" asp-page-handler="Import" class="form-grid">
        <div class="form-row">
            <label asp-for="TimetableCode">时刻表编号</label>
            <input asp-for="TimetableCode" />
        </div>

        <div class="form-row">
            <label asp-for="TimetableName">时刻表名称</label>
            <input asp-for="TimetableName" />
        </div>

        <div class="form-row">
            <label asp-for="LineId">线路 ID</label>
            <input asp-for="LineId" type="number" min="1" />
        </div>

        <div class="form-row">
            <label asp-for="Direction">方向</label>
            <select asp-for="Direction">
                <option value="1">上行</option>
                <option value="2">下行</option>
            </select>
        </div>

        <div class="form-row">
            <label asp-for="VersionNo">版本号</label>
            <input asp-for="VersionNo" />
        </div>

        <div class="form-row">
            <label asp-for="EffectiveStartDate">生效开始日期</label>
            <input asp-for="EffectiveStartDate" type="date" />
        </div>

        <div class="form-row">
            <label asp-for="EffectiveEndDate">生效结束日期</label>
            <input asp-for="EffectiveEndDate" type="date" />
        </div>

        <div class="form-row">
            <label asp-for="RunCalendarType">运行日类型</label>
            <select asp-for="RunCalendarType">
                <option value="DAILY">DAILY</option>
                <option value="WEEKDAY">WEEKDAY</option>
                <option value="WEEKEND">WEEKEND</option>
            </select>
        </div>

        <div class="form-row form-row-full">
            <label asp-for="Remark">备注</label>
            <input asp-for="Remark" />
        </div>

        <div class="form-row form-row-full">
            <label asp-for="UploadFile">CSV 文件</label>
            <input asp-for="UploadFile" type="file" accept=".csv" />
        </div>

        <div class="form-row form-row-full" style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
            <button type="submit">开始导入</button>
            <button type="button" onclick="toggleImportPanel()">收起导入面板</button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.ImportMessage))
    {
        <div class="message-text @(Model.ImportSuccess ? "" : "danger-text")" style="margin-top:16px;">
            @Model.ImportMessage
        </div>
    }

    <div style="margin-top:16px;">
        <strong>CSV 格式：</strong>
        <pre>train_no,station_code,station_seq,arrival_time,departure_time,stop_minutes,is_origin_station,is_terminal_station
            L1-001,A,1,,06:00:00,0,1,0
            L1-001,B,2,06:05:00,06:06:00,1,0,0
            L1-001,C,3,06:10:00,06:11:00,1,0,0
            L1-001,D,4,06:15:00,06:16:00,1,0,0
            L1-001,E,5,06:20:00,,0,0,1</pre>
        </div>
    </div>

    <div class="panel">
        <h3>时刻表列表</h3>

        @if (Model.Timetables.Count == 0)
        {
            <div class="message-text">当前没有时刻表数据。</div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>编号</th>
                        <th>名称</th>
                        <th>线路</th>
                        <th>方向</th>
                        <th>版本</th>
                        <th>生效开始</th>
                        <th>生效结束</th>
                        <th>状态</th>
                        <th>激活状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Timetables)
                    {
                        <tr style="@(Model.TimetableId == item.TimetableId ? "background-color:#eef5ff;" : "")">
                            <td>@item.TimetableId</td>
                            <td>@item.TimetableCode</td>
                            <td>@item.TimetableName</td>
                            <td>@(!string.IsNullOrWhiteSpace(item.LineName) ? item.LineName : $"{item.LineId}号线")</td>
                            <td>@(!string.IsNullOrWhiteSpace(item.DirectionText) ? item.DirectionText : Model.GetDirectionText(item.Direction))</td>
                            <td>@item.VersionNo</td>
                            <td>@item.EffectiveStartDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.EffectiveEndDate.ToString("yyyy-MM-dd")</td>
                            <td>@(!string.IsNullOrWhiteSpace(item.StatusText) ? item.StatusText : Model.GetStatusText(item.Status))</td>
                            <td>@(!string.IsNullOrWhiteSpace(item.ActiveText) ? item.ActiveText : Model.GetActiveText(item.IsActive))</td>
                            <td>
                                <div style="display:flex; gap:8px; justify-content:center; flex-wrap:wrap;">
                                    <a href="/Timetable?TimetableId=@item.TimetableId" class="action-link-btn">查看详情</a>

                                    <form method="post" asp-page-handler="Publish" style="display:inline;">
                                        <input type="hidden" name="timetableId" value="@item.TimetableId" />
                                        <button type="submit">发布</button>
                                    </form>

                                    <form method="post" asp-page-handler="Disable" style="display:inline;">
                                        <input type="hidden" name="timetableId" value="@item.TimetableId" />
                                        <button type="submit">停用</button>
                                    </form>

                                    <form method="post" asp-page-handler="Delete" style="display:inline;"
                                          onsubmit="return confirm('确认删除该时刻表及其全部明细吗？删除后不可恢复。');">
                                        <input type="hidden" name="timetableId" value="@item.TimetableId" />
                                        <button type="submit" class="danger-btn">删除</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="panel">
        <h3>时刻表明细</h3>

        @if (Model.Details.Count == 0)
        {
            <div class="message-text">暂无明细数据。</div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>车次号</th>
                        <th>站序</th>
                        <th>站点编码</th>
                        <th>站点名称</th>
                        <th>到站时间</th>
                        <th>发车时间</th>
                        <th>停站分钟</th>
                        <th>始发站</th>
                        <th>终点站</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Details)
                    {
                        <tr>
                            <td>@item.TrainNo</td>
                            <td>@item.StationSeq</td>
                            <td>@item.StationCode</td>
                            <td>@item.StationName</td>
                            <td>@(string.IsNullOrEmpty(item.ArrivalTime) ? "-" : item.ArrivalTime)</td>
                            <td>@(string.IsNullOrEmpty(item.DepartureTime) ? "-" : item.DepartureTime)</td>
                            <td>@item.StopMinutes</td>
                            <td>@(!string.IsNullOrWhiteSpace(item.OriginText) ? item.OriginText : (item.IsOriginStation == 1 ? "是" : "否"))</td>
                            <td>@(!string.IsNullOrWhiteSpace(item.TerminalText) ? item.TerminalText : (item.IsTerminalStation == 1 ? "是" : "否"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @section Scripts {
        <script>
            function toggleImportPanel() {
                const panel = document.getElementById("importPanel");
                if (!panel) return;

                panel.style.display = panel.style.display === "none" ? "block" : "none";
            }
        </script>
    }