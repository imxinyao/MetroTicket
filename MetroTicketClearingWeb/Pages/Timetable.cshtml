@page
@model MetroTicketClearingWeb.Pages.TimetableModel
@{
    ViewData["Title"] = "时刻表与清分准备";

    string GetClearingReadyText(MetroTicketClearingWeb.Pages.TimetableModel.TimetableHeaderDto item)
    {
        var today = DateTime.Today;

        if (item.Status != 1)
        {
            return "未发布，不参与时刻表清分";
        }

        if (item.IsActive != 1)
        {
            return "未激活，不参与时刻表清分";
        }

        if (item.EffectiveStartDate.Date > today)
        {
            return "尚未生效，当前不参与时刻表清分";
        }

        if (item.EffectiveEndDate.Date < today)
        {
            return "已过期，当前不参与时刻表清分";
        }

        return "可用于时刻表清分";
    }

    string GetClearingReadyClass(MetroTicketClearingWeb.Pages.TimetableModel.TimetableHeaderDto item)
    {
        var today = DateTime.Today;

        if (item.Status == 1 &&
            item.IsActive == 1 &&
            item.EffectiveStartDate.Date <= today &&
            item.EffectiveEndDate.Date >= today)
        {
            return "success-text";
        }

        return "danger-text";
    }
}

<div class="header page-header">
    <div>
        <h1>时刻表与清分准备</h1>
        <p class="sub-text">用于查看时刻表主数据，并为后续刷卡匹配与清分提供基础。</p>
    </div>
    <div>
        <button type="button" onclick="toggleImportPanel()">导入时刻表</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="panel">
        <div class="message-text danger-text">@Model.ErrorMessage</div>
    </div>
}

<div class="panel" id="importPanel" style="display:@(!string.IsNullOrWhiteSpace(Model.ImportMessage) ? "block" : "none");">
    <h3>时刻表导入</h3>

    <form method="post" enctype="multipart/form-data" asp-page-handler="Import" class="form-grid">
        <div class="form-row">
            <label asp-for="TimetableCode">时刻表编号</label>
            <input asp-for="TimetableCode" />
        </div>

        <div class="form-row">
            <label asp-for="TimetableName">时刻表名称</label>
            <input asp-for="TimetableName" />
        </div>

        <div class="form-row">
            <label asp-for="LineId">线路 ID</label>
            <input asp-for="LineId" type="number" min="1" />
        </div>

        <div class="form-row">
            <label asp-for="Direction">方向</label>
            <select asp-for="Direction">
                <option value="1">上行</option>
                <option value="2">下行</option>
            </select>
        </div>

        <div class="form-row">
            <label asp-for="VersionNo">版本号</label>
            <input asp-for="VersionNo" />
        </div>

        <div class="form-row">
            <label asp-for="EffectiveStartDate">生效开始日期</label>
            <input asp-for="EffectiveStartDate" type="date" />
        </div>

        <div class="form-row">
            <label asp-for="EffectiveEndDate">生效结束日期</label>
            <input asp-for="EffectiveEndDate" type="date" />
        </div>

        <div class="form-row">
            <label asp-for="RunCalendarType">运行日类型</label>
            <select asp-for="RunCalendarType">
                <option value="DAILY">DAILY</option>
                <option value="WEEKDAY">WEEKDAY</option>
                <option value="WEEKEND">WEEKEND</option>
            </select>
        </div>

        <div class="form-row form-row-full">
            <label asp-for="Remark">备注</label>
            <input asp-for="Remark" />
        </div>

        <div class="form-row form-row-full">
            <label asp-for="UploadFile">CSV 文件</label>
            <input asp-for="UploadFile" type="file" accept=".csv" />
        </div>

        <div class="form-row form-row-full" style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
            <button type="submit">开始导入</button>
            <button type="button" onclick="toggleImportPanel()">收起导入面板</button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.ImportMessage))
    {
        <div class="message-text @(Model.ImportSuccess ? "" : "danger-text")" style="margin-top:16px;">
            @Model.ImportMessage
        </div>
    }

    <div style="margin-top:16px;">
        <strong>CSV 格式：</strong>
        <pre>train_no,station_code,station_seq,arrival_time,departure_time,stop_minutes,is_origin_station,is_terminal_station
L1-001,A,1,,06:00:00,0,1,0
L1-001,B,2,06:05:00,06:06:00,1,0,0
L1-001,C,3,06:10:00,06:11:00,1,0,0
L1-001,D,4,06:15:00,06:16:00,1,0,0
L1-001,E,5,06:20:00,,0,0,1</pre>
    </div>
</div>

<div class="panel">
    <h3>时刻表列表</h3>

    @if (Model.Timetables.Count == 0)
    {
        <div class="message-text">当前没有时刻表数据。</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>序号</th>
                    <th>编号</th>
                    <th>名称</th>
                    <th>线路</th>
                    <th>方向</th>
                    <th>版本</th>
                    <th>生效开始</th>
                    <th>生效结束</th>
                    <th>状态</th>
                    <th>激活状态</th>
                    <th>清分可用性</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var orderedTimetables = Model.Timetables.OrderBy(x => x.TimetableId).ToList();
                }

                @for (int i = 0; i < orderedTimetables.Count; i++)
                {
                    var item = orderedTimetables[i];

                    <tr style="@(Model.TimetableId == item.TimetableId ? "background-color:#eef5ff;" : "")">
                        <td>@(i + 1)</td>
                        <td>@item.TimetableCode</td>
                        <td>@item.TimetableName</td>
                        <td>@(!string.IsNullOrWhiteSpace(item.LineName) ? item.LineName : $"{item.LineId}号线")</td>
                        <td>@(!string.IsNullOrWhiteSpace(item.DirectionText) ? item.DirectionText : Model.GetDirectionText(item.Direction))</td>
                        <td>@item.VersionNo</td>
                        <td>@item.EffectiveStartDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.EffectiveEndDate.ToString("yyyy-MM-dd")</td>
                        <td class="@(item.Status == 1 ? "success-text" : "danger-text")">
                            @(!string.IsNullOrWhiteSpace(item.StatusText) ? item.StatusText : Model.GetStatusText(item.Status))
                        </td>
                        <td class="@(item.IsActive == 1 ? "success-text" : "danger-text")">
                            @(!string.IsNullOrWhiteSpace(item.ActiveText) ? item.ActiveText : Model.GetActiveText(item.IsActive))
                        </td>
                        <td class="@GetClearingReadyClass(item)">
                            @GetClearingReadyText(item)
                        </td>
                        <td>
                            <div style="display:flex; gap:8px; justify-content:center; flex-wrap:wrap;">
                                <a href="/Timetable?TimetableId=@item.TimetableId" class="action-link-btn">查看详情</a>

                                <form method="post" asp-page-handler="Publish" style="display:inline;">
                                    <input type="hidden" name="timetableId" value="@item.TimetableId" />
                                    <button type="submit">发布</button>
                                </form>

                                <form method="post" asp-page-handler="Disable" style="display:inline;">
                                    <input type="hidden" name="timetableId" value="@item.TimetableId" />
                                    <button type="submit">停用</button>
                                </form>

                                <form method="post"
                                      asp-page-handler="Delete"
                                      style="display:inline;"
                                      onsubmit="return confirm('确认删除该时刻表及其全部明细吗？删除后不可恢复。');">
                                    <input type="hidden" name="timetableId" value="@item.TimetableId" />
                                    <button type="submit" class="danger-btn">删除</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="panel">
    <h3>当前选中时刻表摘要</h3>

    @if (Model.SelectedTimetable == null)
    {
        <div class="message-text">请先在上方列表中选择一个时刻表。</div>
    }
    else
    {
        var selected = Model.SelectedTimetable;

        <div class="message-text @GetClearingReadyClass(selected)" style="margin-bottom:16px;">
            清分可用性：@GetClearingReadyText(selected)
        </div>

        <div class="summary-grid">
            <div class="summary-item">
                <div class="summary-label">时刻表编号</div>
                <div class="summary-value">@selected.TimetableCode</div>
            </div>

            <div class="summary-item">
                <div class="summary-label">时刻表名称</div>
                <div class="summary-value">@selected.TimetableName</div>
            </div>

            <div class="summary-item">
                <div class="summary-label">所属线路</div>
                <div class="summary-value">@(!string.IsNullOrWhiteSpace(selected.LineName) ? selected.LineName : $"{selected.LineId}号线")</div>
            </div>

            <div class="summary-item">
                <div class="summary-label">运行方向</div>
                <div class="summary-value">@(!string.IsNullOrWhiteSpace(selected.DirectionText) ? selected.DirectionText : Model.GetDirectionText(selected.Direction))</div>
            </div>

            <div class="summary-item">
                <div class="summary-label">版本号</div>
                <div class="summary-value">@selected.VersionNo</div>
            </div>

            <div class="summary-item">
                <div class="summary-label">运行日类型</div>
                <div class="summary-value">@selected.RunCalendarType</div>
            </div>

            <div class="summary-item">
                <div class="summary-label">生效开始</div>
                <div class="summary-value">@selected.EffectiveStartDate.ToString("yyyy-MM-dd")</div>
            </div>

            <div class="summary-item">
                <div class="summary-label">生效结束</div>
                <div class="summary-value">@selected.EffectiveEndDate.ToString("yyyy-MM-dd")</div>
            </div>

            <div class="summary-item">
                <div class="summary-label">发布状态</div>
                <div class="summary-value">@(!string.IsNullOrWhiteSpace(selected.StatusText) ? selected.StatusText : Model.GetStatusText(selected.Status))</div>
            </div>

            <div class="summary-item">
                <div class="summary-label">激活状态</div>
                <div class="summary-value">@(!string.IsNullOrWhiteSpace(selected.ActiveText) ? selected.ActiveText : Model.GetActiveText(selected.IsActive))</div>
            </div>

            <div class="summary-item summary-item-wide">
                <div class="summary-label">备注</div>
                <div class="summary-value">@(!string.IsNullOrWhiteSpace(selected.Remark) ? selected.Remark : "无")</div>
            </div>
        </div>
    }
</div>

<div class="panel">
    <h3>时刻表明细（按车次分组）</h3>

    @if (Model.SelectedTimetable == null)
    {
        <div class="message-text">请先在上方列表中选择一个时刻表后查看明细。</div>
    }
    else if (Model.GroupedDetails.Count == 0)
    {
        <div class="message-text">暂无明细数据。</div>
    }
    else
    {
        <div class="detail-note">
            当前明细已按 <strong>车次号</strong> 分组展示。每组先展示列车运行区间，再展示各停靠站的到发时间与停站分钟，更适合课堂演示时逐车次说明。
        </div>

        @for (int i = 0; i < Model.GroupedDetails.Count; i++)
        {
            var group = Model.GroupedDetails[i];
            var groupIndex = i + 1;

            <div class="train-group-block">
                <div class="train-group-header">
                    <div>
                        <div class="train-group-title">车次 @group.TrainNo</div>
                        <div class="train-group-subtitle">
                            第 @groupIndex 组，共 @group.Items.Count 个停靠点，
                            运行区间：@group.StartStationName → @group.EndStationName
                        </div>
                    </div>
                </div>

                <table class="detail-group-table">
                    <thead>
                        <tr>
                            <th style="width:80px;">组序</th>
                            <th style="width:120px;">车次号</th>
                            <th style="width:220px;">运行区间</th>
                            <th style="width:90px;">站序</th>
                            <th style="width:120px;">站点编码</th>
                            <th>站点名称</th>
                            <th style="width:110px;">到站时间</th>
                            <th style="width:110px;">发车时间</th>
                            <th style="width:100px;">停站分钟</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int j = 0; j < group.Items.Count; j++)
                        {
                            var item = group.Items[j];
                            var stationTag = item.IsOriginStation == 1
                                ? "始发站"
                                : item.IsTerminalStation == 1
                                    ? "终到站"
                                    : "中间站";

                            <tr>
                                @if (j == 0)
                                {
                                    <td rowspan="@group.Items.Count" class="merged-cell">@groupIndex</td>
                                    <td rowspan="@group.Items.Count" class="merged-cell">@group.TrainNo</td>
                                    <td rowspan="@group.Items.Count" class="merged-cell">
                                        @group.StartStationName → @group.EndStationName
                                    </td>
                                }

                                <td>@item.StationSeq</td>
                                <td>@item.StationCode</td>
                                <td>
                                    <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                                        <span>@item.StationName</span>
                                        <span class="station-tag @(item.IsOriginStation == 1 ? "station-tag-start" : item.IsTerminalStation == 1 ? "station-tag-end" : "station-tag-middle")">
                                            @stationTag
                                        </span>
                                    </div>
                                </td>
                                <td>@(string.IsNullOrEmpty(item.ArrivalTime) ? "-" : item.ArrivalTime)</td>
                                <td>@(string.IsNullOrEmpty(item.DepartureTime) ? "-" : item.DepartureTime)</td>
                                <td>@item.StopMinutes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        function toggleImportPanel() {
            const panel = document.getElementById("importPanel");
            if (!panel) return;

            panel.style.display = panel.style.display === "none" ? "block" : "none";
        }
    </script>
}

<style>
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .summary-item {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 14px 16px;
        background: #fafcff;
    }

    .summary-item-wide {
        grid-column: span 2;
    }

    .summary-label {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 6px;
    }

    .summary-value {
        font-size: 15px;
        font-weight: 600;
        color: #111827;
        word-break: break-word;
    }

    .detail-note {
        margin-bottom: 16px;
        color: #4b5563;
        line-height: 1.7;
    }

    .train-group-block {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 20px;
        background: #ffffff;
    }

    .train-group-header {
        padding: 14px 16px;
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
    }

    .train-group-title {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .train-group-subtitle {
        font-size: 13px;
        color: #6b7280;
    }

    .detail-group-table {
        width: 100%;
        border-collapse: collapse;
    }

        .detail-group-table th,
        .detail-group-table td {
            border: 1px solid #e5e7eb;
            padding: 10px 12px;
            text-align: center;
            vertical-align: middle;
        }

        .detail-group-table th {
            background: #f9fafb;
            font-weight: 600;
        }

    .merged-cell {
        background: #fcfcfd;
        font-weight: 600;
    }

    .station-tag {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        line-height: 1.4;
    }

    .station-tag-start {
        background: #e8f7ec;
        color: #198754;
    }

    .station-tag-end {
        background: #fff1f1;
        color: #dc3545;
    }

    .station-tag-middle {
        background: #eef2f7;
        color: #495057;
    }

    @@media (max-width: 1200px) {
        .summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .summary-item-wide {
            grid-column: span 2;
        }
    }

    @@media (max-width: 768px) {
        .summary-grid {
            grid-template-columns: 1fr;
        }

        .summary-item-wide {
            grid-column: span 1;
        }
    }
</style>