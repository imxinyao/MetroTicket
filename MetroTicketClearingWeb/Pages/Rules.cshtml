@page
@model MetroTicketClearingWeb.Pages.RulesModel
@{
    ViewData["Title"] = "清分规则配置";
}

<div class="header">
    <h1>清分规则配置</h1>
</div>

<div class="panel">
    <h3>票价规则</h3>
    <div class="rule-text">
        <p>0 - 3 公里：2 元</p>
        <p>3 - 6 公里：3 元</p>
        <p>6 - 10 公里：4 元</p>
        <p>10 公里以上：5 元</p>
    </div>

    <h3 class="section-title">清分模式</h3>
    <select id="clearingMode">
        <option value="shortest">最短路径清分</option>
        <option value="multi">多路径概率清分</option>
    </select>

    <h3 class="section-title">换乘贡献系数</h3>
    <input type="text" id="transferFactorInput" value="1.1">

    <h3 class="section-title">规则说明</h3>
    <div class="rule-text">
        <p>1. 单次交易票价按照乘客实际最短路径总里程进行分段计价。</p>
        <p>2. 0 - 3 公里按 2 元计费，3 - 6 公里按 3 元计费，6 - 10 公里按 4 元计费，10 公里以上按 5 元计费。</p>
        <p>3. 涉及换乘的交易，按各线路承担的里程比例进行清分。</p>
        <p>4. 换乘站可结合换乘贡献系数进行加权分摊。</p>
        <p>5. 异常交易按异常规则单独处理，不参与正常路径清分。</p>
    </div>

    <div id="saveMessage" class="message-text" style="margin-top: 16px;"></div>

    <div style="margin-top: 20px;">
        <button onclick="saveRule()">保存规则</button>
    </div>
</div>

@section Scripts {
    <script>
        function saveRule() {
            const factorInput = document.getElementById("transferFactorInput");
            const clearingMode = document.getElementById("clearingMode").value;
            const saveMessage = document.getElementById("saveMessage");

            const transferFactor = parseFloat(factorInput.value);

            if (isNaN(transferFactor) || transferFactor <= 0) {
                saveMessage.textContent = "保存失败：请输入大于 0 的有效换乘贡献系数。";
                saveMessage.className = "message-text danger-text";
                return;
            }

            localStorage.setItem("transferFactor", transferFactor.toString());
            localStorage.setItem("clearingMode", clearingMode);

            saveMessage.textContent = `规则已保存：换乘贡献系数 = ${transferFactor}，清分模式 = ${clearingMode === "shortest" ? "最短路径清分" : "多路径概率清分"}`;
            saveMessage.className = "message-text success-text";
            alert("规则保存成功！");
        }

        window.onload = function () {
            const savedFactor = localStorage.getItem("transferFactor");
            const savedMode = localStorage.getItem("clearingMode");

            if (savedFactor) {
                document.getElementById("transferFactorInput").value = savedFactor;
            }

            if (savedMode) {
                document.getElementById("clearingMode").value = savedMode;
            }
        };
    </script>
}