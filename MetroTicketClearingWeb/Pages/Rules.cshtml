@page
@model MetroTicketClearingWeb.Pages.RulesModel
@{
    ViewData["Title"] = "清分规则配置";
}

<div class="header">
    <h1>清分规则配置</h1>
</div>

<div class="panel">
    <h3>票价规则</h3>
    <div class="rule-text">
        <p>0 - 3 公里：2 元</p>
        <p>3 - 6 公里：3 元</p>
        <p>6 - 10 公里：4 元</p>
        <p>10 公里以上：5 元</p>
    </div>

    <h3 class="section-title">清分模式</h3>
    <select id="clearingMode">
        <option value="shortest">最短路径清分</option>
        <option value="multi">多路径概率清分</option>
    </select>

    <div id="transferFactorSection">
        <h3 class="section-title">换乘贡献系数</h3>
        <input type="text" id="transferFactorInput" value="1.1">
    </div>

    <h3 class="section-title">规则说明</h3>
    <div class="rule-text">
        <p>1. 单次交易票价按照乘客实际最短路径总里程进行分段计价。</p>
        <p>2. 0 - 3 公里按 2 元计费，3 - 6 公里按 3 元计费，6 - 10 公里按 4 元计费，10 公里以上按 5 元计费。</p>
        <p>3. 最短路径清分模式下，涉及换乘的交易，可结合换乘贡献系数进行加权分摊。</p>
        <p>4. 多路径概率清分模式下，按候选路径概率进行分摊，不使用换乘贡献系数。</p>
        <p>5. 异常交易按异常规则单独处理，不参与正常路径清分。</p>
    </div>

    <div id="saveMessage" class="message-text" style="margin-top: 16px;"></div>

    <div style="margin-top: 20px;">
        <button type="button" onclick="saveRule()">保存规则</button>
    </div>
</div>

<div id="page-config" data-api-base-url="@Model.ApiBaseUrl"></div>

@section Scripts {
    <script>
        const apiBaseUrl = document.getElementById("page-config").dataset.apiBaseUrl + "/api";

        function updateTransferFactorVisibility() {
            const clearingMode = document.getElementById("clearingMode").value;
            const transferFactorSection = document.getElementById("transferFactorSection");

            // 多路径概率清分不使用换乘贡献系数，但为了让用户能看到当前值，也可以选择不隐藏。
            // 这里按你的页面说明：multi 模式下隐藏。
            transferFactorSection.style.display = clearingMode === "multi" ? "none" : "block";
        }

        async function loadRule() {
            const saveMessage = document.getElementById("saveMessage");

            try {
                saveMessage.textContent = "正在读取规则配置...";

                const response = await fetch(`${apiBaseUrl}/Clearing/rules`);

                if (!response.ok) {
                    const text = await response.text();
                    throw new Error(`读取规则失败：${response.status} ${text}`);
                }

                const data = await response.json();

                document.getElementById("clearingMode").value = data.clearingMode || "shortest";
                document.getElementById("transferFactorInput").value = data.transferCoefficient ?? "1.1";

                updateTransferFactorVisibility();

                if ((data.clearingMode || "shortest") === "multi") {
                    saveMessage.textContent = "规则配置读取成功。当前模式：多路径概率清分，该模式不使用换乘贡献系数。";
                } else {
                    saveMessage.textContent = `规则配置读取成功。当前模式：最短路径清分，换乘贡献系数：${data.transferCoefficient ?? "1.1"}`;
                }
            } catch (error) {
                console.error(error);
                saveMessage.textContent = "规则读取失败，请检查后端服务是否启动。";
            }
        }

        async function saveRule() {
            const clearingMode = document.getElementById("clearingMode").value;
            const transferFactorInput = document.getElementById("transferFactorInput").value.trim();
            const saveMessage = document.getElementById("saveMessage");

            const transferFactor = parseFloat(transferFactorInput);

            if (Number.isNaN(transferFactor) || transferFactor <= 0) {
                saveMessage.textContent = "保存失败：换乘贡献系数必须是大于 0 的数字。";
                return;
            }

            try {
                saveMessage.textContent = "正在保存规则...";

                const response = await fetch(`${apiBaseUrl}/Clearing/rules`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        clearingMode: clearingMode,
                        transferCoefficient: transferFactor
                    })
                });

                if (!response.ok) {
                    const text = await response.text();
                    throw new Error(`保存规则失败：${response.status} ${text}`);
                }

                const data = await response.json();

                if (data.clearingMode === "multi") {
                    saveMessage.textContent = "规则保存成功。当前模式：多路径概率清分。该模式不使用换乘贡献系数。";
                } else {
                    saveMessage.textContent = `规则保存成功。当前模式：最短路径清分，换乘贡献系数：${data.transferCoefficient}`;
                }

                updateTransferFactorVisibility();
            } catch (error) {
                console.error(error);
                saveMessage.textContent = "规则保存失败，请检查后端服务或数据库配置。";
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            loadRule();

            document.getElementById("clearingMode").addEventListener("change", function () {
                updateTransferFactorVisibility();
            });
        });
    </script>
}